{
	"info": {
		"_postman_id": "9a1b2c3d-5e6f-7g8h-9i0j-1k2l3m4n5o6p",
		"name": "SaaS Cabelereiro - Completo",
		"description": "API para gestão de usuários, cursos, sessões e inscrições.",
